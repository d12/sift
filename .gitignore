# ── Xcode generated artifacts ────────────────────────────────────────────────
# Sift.xcodeproj is fully generated by XcodeGen (project.yml).
# Never commit it — it embeds your personal Team ID and local paths.
Sift.xcodeproj/

# Xcode build cache
DerivedData/
build/
*.xcarchive

# Xcode user-specific state (window layout, breakpoints, etc.)
*.xcuserstate
xcuserdata/

# ── Local signing config ──────────────────────────────────────────────────────
# Create this file locally for Release signing; never commit it.
# Contents example:
#   DEVELOPMENT_TEAM = A1B2C3D4E5
#   CODE_SIGN_IDENTITY = Developer ID Application
local.xcconfig

# ── Certificates & keys (safety net) ─────────────────────────────────────────
*.p12
*.cer
*.mobileprovision

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Swift Package Manager ─────────────────────────────────────────────────────
# Package.resolved is managed inside Sift.xcodeproj (already gitignored above)
.build/
